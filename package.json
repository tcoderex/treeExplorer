{
  "name": "the-arabic-area",
  "version": "6.0.0",
  "description": "The Arabic Area: Windows 11 styled family tree explorer for handling 1000+ members",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "build:exe": "vite build && electron-builder --win"
  },
  "keywords": [
    "family-tree",
    "windows-11",
    "fluent",
    "genealogy"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "jimp": "^1.6.1",
    "vite": "^5.3.1"
  },
  "build": {
    "electronVersion": "31.7.7",
    "appId": "com.win11.thearabicarea",
    "productName": "The Arabic Area",
    "win": {
      "icon": "build/icon.png",
      "target": [
        "dir",
        "zip",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "build/installerSidebar.png",
      "installerHeader": "build/installerHeader.png",
      "uninstallDisplayName": "The Arabic Area",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "splash.html",
      "package.json",
      "build/icon.png"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "google-translate-api-browser": "^5.0.0"
  }
}
